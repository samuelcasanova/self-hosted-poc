# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Backblaze B2 ─────────────────────────────────────────────────────────────
# 1. Create a bucket at backblaze.com (Private, no public access)
# 2. Go to App Keys → Add Application Key
#    - Restrict to your bucket, Read+Write access
# 3. Copy keyID and applicationKey below.

B2_ACCOUNT_ID=your_key_id_here
B2_ACCOUNT_KEY=your_application_key_here

# Repository path: b2:<bucket-name>:/restic
# The /restic prefix is just a folder inside the bucket.
RESTIC_REPOSITORY=b2:my-homelab-backup:/restic

# Strong random password — restic uses this to encrypt your data.
# Store it somewhere safe (e.g. a password manager). Without it you cannot restore.
RESTIC_PASSWORD=change_me_to_a_strong_random_password

# ── Telegram ─────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the API token
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id in the response JSON.

TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Schedule ─────────────────────────────────────────────────────────────────
# Cron expression for when the backup runs (default: 2 AM every day).
# Examples: "0 2 * * *" (daily at 02:00), "0 */6 * * *" (every 6 hours)
BACKUP_CRON=0 2 * * *

# ── VaultWarden ──────────────────────────────────────────────────────────────
# Full URL where VaultWarden will be reachable (used for WebAuthn and email links).
VAULTWARDEN_DOMAIN=https://vault.yourdomain.com

# Admin panel token — generate with: docker run --rm -it vaultwarden/server /vaultwarden hash
# Then paste the output here (the $$ prefix escapes $ in docker-compose env files).
VAULTWARDEN_ADMIN_TOKEN=change_me_to_a_strong_random_token

# ── Frigate / Security camera ─────────────────────────────────────────────────
# Set to "true" to enable Telegram notifications when motion is detected.
# Restart the frigate-notifier container after changing this value.
# In a real setup this would come from Home Assistant as a boolean helper.
ALARM_ACTIVE=false

# Seconds to suppress duplicate notifications after one fires (default: 60)
COOLDOWN_SECONDS=60

# Comma-separated list of object labels to notify for (Frigate COCO labels)
TRACKED_LABELS=person
